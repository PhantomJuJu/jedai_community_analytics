# ローカルで npm run dev する際にコピーして .env として編集してください。
# cp .env.example .env

# 必須: ワークスペース URL（末尾スラッシュなし）
DATABRICKS_HOST=https://your-workspace.cloud.databricks.com

# 必須: Personal Access Token（User Settings で発行）
DATABRICKS_TOKEN=

# 必須: SQL Warehouse ID（ウェアハウス画面の ID）
DATABRICKS_WAREHOUSE_ID=

# 任意: Apps から実行する Notebook Job の Job ID（Jobs UI の URL 末尾）
# 例: https://<workspace>#job/123456 の場合は 123456
DATABRICKS_NOTEBOOK_JOB_ID=

# 任意: ~/.databrickscfg のプロファイル名（ホスト/トークンと併用可）
# DATABRICKS_CONFIG_PROFILE=DEFAULT

# 任意: Databricks AI/BI Genie Space ID（Genie タブ）。未設定時は設定案内を表示
# Genie Space の About タブから取得
# DATABRICKS_GENIE_SPACE_ID=

# 任意: EC2 Discord Bot API（予約投稿）。未設定時は Discord 送信 UI を無効表示
# DISCORD_API_URL=http://YOUR_EC2_PUBLIC_IP:8080
# DISCORD_API_SECRET=
# DISCORD_GUILD_ID=
