    {
      "name": "466e9b29",
      "displayName": "activity_by_weekday_hour",
      "queryLines": [
        "SELECT * FROM kazuki_jedai.gold.activity_by_weekday_hour"
      ],
      "columns": [
        {
          "displayName": "曜日名",
          "description": "Weekday name in Japanese (Spark dayofweek: 1=Sun)",
          "expression": "CASE WHEN `weekday` = 1 THEN '日' WHEN `weekday` = 2 THEN '月' WHEN `weekday` = 3 THEN '火' WHEN `weekday` = 4 THEN '水' WHEN `weekday` = 5 THEN '木' WHEN `weekday` = 6 THEN '金' WHEN `weekday` = 7 THEN '土' ELSE CAST(`weekday` AS STRING) END"
        },
        {
          "displayName": "ボイス時間（時間）",
          "description": "Voice duration in hours",
          "expression": "`voice_duration_seconds_aggregated` / 3600"
        }
      ]
    },
