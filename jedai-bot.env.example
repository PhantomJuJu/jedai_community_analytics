# Copy to jedai-bot.env and fill in real values (jedai-bot.env is gitignored).
# chmod 600 jedai-bot.env
#
# Run: ./scripts/01_setup/run_jedai_bot_docker.sh

DISCORD_BOT_TOKEN=

DATABRICKS_SQL_WAREHOUSE_SERVER_HOSTNAME=
DATABRICKS_SQL_WAREHOUSE_HTTP_PATH=
DATABRICKS_ACCESS_TOKEN=
DATABRICKS_CATALOG=
DATABRICKS_SCHEMA=

# Optional: HTTP API (see bot.py / api_server.py)
# API_ENABLED=true
# API_PORT=8080
# API_SECRET_KEY=

# Optional: announce whitelist controls
# - Bot now uses whitelist-only candidates (no all-channel/all-role fallback).
# - If ANNOUNCE_GUILD_ID is set, whitelist is applied only to that guild.
# - Legacy aliases are also accepted:
#   WHITELIST_GUILD_ID, WHITELIST_CHANNEL_IDS, WHITELIST_ROLE_IDS,
#   ALLOWED_CHANNEL_IDS, ALLOWED_ROLE_IDS
# ANNOUNCE_GUILD_ID=000000000000000000
# ANNOUNCE_CHANNEL_IDS=000000000000000000,000000000000000000,000000000000000000,000000000000000000
# ANNOUNCE_ROLE_IDS=000000000000000000,000000000000000000,000000000000000000,000000000000000000,000000000000000000

# Optional: passed through if you use external tooling (not read by current bot scripts)
# AZURE_DEVOPS_ORG=
# AZURE_DEVOPS_PAT=
# DATABRICKS_WORKSPACE_URL=
